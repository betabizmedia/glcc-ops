# ============================================================
# GLCC Starter — environment variables
# Copy this file to ".env" and fill in your own values.
# NEVER commit your real .env (it's already in .gitignore).
# ============================================================

# --- Supabase (set in the O step) ---
# Settings -> Data API -> Project URL. Use the BASE url only:
#   https://YOUR-PROJECT.supabase.co   (NOT the .../rest/v1 endpoint)
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# Settings -> API Keys -> service_role (click Reveal). MUST be service_role, NOT
# the anon/publishable key — anon can't read past row-level security, so the
# dashboard would come up EMPTY. SERVER-ONLY: never put it in a "use client" file.
# Paste it as ONE line, with NO trailing space or newline (a stray newline makes
# every request fail with "Headers.set: invalid header value").
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Anthropic (set in the N step) ---
# console.anthropic.com -> Settings -> API Keys
ANTHROPIC_API_KEY=sk-ant-...

# --- Telegram (set in the N step) ---
# From @BotFather after /newbot
TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token
# Any random string you make up — must match what you pass to setWebhook
TELEGRAM_WEBHOOK_SECRET=make-up-a-long-random-string
# Your numeric Telegram user id from @userinfobot (comma-separate for more people)
TELEGRAM_ALLOWED_USER_IDS=812345678
# Where the daily digest is sent — a SINGLE numeric id, no commas (usually your own id)
OWNER_CHAT_ID=812345678
# Optional — the proactive agent (Jarvis Oyen) also pings these teammates.
# Comma-separated numeric ids. Leave BLANK to just message yourself (OWNER_CHAT_ID).
# TELEGRAM_TEAM_CHAT_IDS=812345678,987654321

# --- Meta Ads report (set for the /api/ads-report cron) ---
# The numeric ad account id ONLY (no "act_" prefix — the route adds it).
# SUMA College Corporate Training / Part Time:
META_AD_ACCOUNT_ID=1674508473342349
# A Meta token with the "ads_read" permission on that account. Recommended: a
# System User token (Business Settings -> Users -> System Users -> Generate token,
# pick your app + ads_read) — it does NOT expire, so the daily cron never breaks.
# Fallback: a 60-day long-lived user token from Graph API Explorer (must be renewed).
META_ACCESS_TOKEN=your-meta-system-user-token
# Optional override: which action_type counts as a "lead". Default "lead" matches
# Ads Manager for this account. Only set this if the lead count looks wrong.
# META_LEAD_ACTION_TYPE=lead

# --- Cron security ---
# Vercel Cron sends this as a Bearer token. The digest runs without it, but
# Jarvis Oyen only SENDS its team broadcast when CRON_SECRET is set (fail-closed).
# Set it to switch on the daily agent ping and lock down both crons.
# CRON_SECRET=make-up-another-long-random-string
